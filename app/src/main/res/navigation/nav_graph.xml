<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/mapFragment">

    <fragment android:id="@+id/mapFragment"
        android:name="com.rut.campusnavigation.presentation.map.MapFragment"
        android:label="Карта">
        <action android:id="@+id/action_mapFragment_to_searchFragment"
            app:destination="@id/searchFragment"/>
        <action android:id="@+id/action_mapFragment_to_favoritesFragment"
            app:destination="@id/favoritesFragment"/>
    </fragment>

    <fragment android:id="@+id/searchFragment"
        android:name="com.rut.campusnavigation.presentation.search.SearchFragment"
        android:label="Поиск"/>

    <fragment android:id="@+id/favoritesFragment"
        android:name="com.rut.campusnavigation.presentation.favorites.FavoritesFragment"
        android:label="Избранное">
        <action android:id="@+id/action_favoritesFragment_to_addFavoriteFragment"
            app:destination="@id/addFavoriteFragment"/>
        <action android:id="@+id/action_favoritesFragment_to_mapFragment"
            app:destination="@id/mapFragment"
            app:popUpTo="@id/mapFragment"
            app:popUpToInclusive="false"/>
    </fragment>

    <fragment android:id="@+id/addFavoriteFragment"
        android:name="com.rut.campusnavigation.presentation.favorites.AddFavoriteFragment"
        android:label="Добавить в избранное"/>

</navigation>
